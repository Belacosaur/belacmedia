{
  "brand": "Belac Media",
  "tagline": "Modern Australian Premium",
  "region": "Perth, Western Australia, Australia",
  "colors": {
    "midnight": { "hex": "#121414", "usage": "Hero backgrounds, footer, primary dark surfaces" },
    "midnight_soft": { "hex": "#1a1c1c", "usage": "Gradients, elevated dark panels" },
    "gold": { "hex": "#c5a059", "usage": "Accent, links on dark, highlights" },
    "gold_dim": { "hex": "#9a7d46", "usage": "Muted gold, hover states on light" },
    "surface": { "hex": "#fcf8f8", "usage": "Primary light page background" },
    "surface_low": { "hex": "#f6f3f2", "usage": "Alternate sections, cards" },
    "surface_container": { "hex": "#f1edec", "usage": "Inset panels, subtle fills" },
    "on_surface": { "hex": "#1c1b1b", "usage": "Primary text on light" },
    "on_surface_variant": { "hex": "#434747", "usage": "Secondary text on light" },
    "hero_ink": { "hex": "#f4f0ef", "usage": "Primary text on midnight" },
    "hero_ink_muted": { "hex": "rgba(244, 240, 239, 0.68)", "usage": "Secondary text on midnight" },
    "outline": { "hex": "rgba(116, 120, 120, 0.35)", "usage": "Borders, dividers (light UI)" }
  },
  "typography": {
    "display_serif": {
      "family": "'Noto Serif', Georgia, 'Times New Roman', serif",
      "weights": [600, 700],
      "usage": "Headlines, hero wordmark feel, editorial emphasis"
    },
    "ui_sans": {
      "family": "'Space Grotesk', system-ui, sans-serif",
      "weights": [400, 500, 600, 700],
      "usage": "Navigation, labels, body on marketing site, buttons"
    },
    "fallback_stack": "var(--font-sans) from global theme where Space Grotesk unavailable"
  },
  "layout": {
    "max_content_width": "1280px",
    "css_token": "--bp-container"
  },
  "logos": [
    {
      "id": "symbol",
      "file": "/logosymbol.png",
      "role": "Favicon-scale mark, tight spaces, mobile nav"
    },
    {
      "id": "letter",
      "file": "/symbolletterlogo.png",
      "role": "Lettermark, footer, mid-width placements"
    },
    {
      "id": "horizontal",
      "file": "/symbolhorizontallogo.png",
      "role": "Primary horizontal lockup, header desktop"
    },
    {
      "id": "vertical",
      "file": "/symbolverticallogo.png",
      "role": "Hero splash, posters, vertical compositions"
    }
  ],
  "contact": {
    "email": "hello@belacmedia.com",
    "web": "https://belacmedia.com"
  },
  "voice": {
    "pillars": [
      "Relief over hype — consistency and approvals, not guaranteed virality",
      "Australian plain English — confident, not corporate jargon",
      "Premium restraint — midnight, gold, serif/sans pairing"
    ],
    "avoid": [
      "Promising viral reach or guaranteed social spikes",
      "Generic growth-hack tone"
    ]
  }
}
