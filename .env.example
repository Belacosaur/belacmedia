# No trailing slash. Used for canonicals, OG/JSON-LD, and dist robots/sitemap.
VITE_SITE_ORIGIN=https://belacmedia.com
# Optional override for sitemap <lastmod> (YYYY-MM-DD). If omitted, build date is used.
# VITE_SITEMAP_LASTMOD=2026-05-06
VITE_API_URL=http://localhost:4000
# Same Web client ID as backend GOOGLE_CLIENT_ID (Google Cloud Console → APIs & Services → Credentials)
VITE_GOOGLE_CLIENT_ID=
# Direct GA4: Measurement ID (G-XXXXXXXXXX). Vite injects the official gtag.js block into index.html.
VITE_GA_MEASUREMENT_ID=
# Optional: GA4 DebugView
# VITE_GA_DEBUG=true

# Optional: GTM only — leave VITE_GA_MEASUREMENT_ID empty if GA4 is fired solely via Tag Manager.
# VITE_GTM_ID=GTM-XXXXXXX
