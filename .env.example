VITE_API_URL=http://localhost:4000
# Same Web client ID as backend GOOGLE_CLIENT_ID (Google Cloud Console → APIs & Services → Credentials)
VITE_GOOGLE_CLIENT_ID=
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Loads gtag.js + SPA page_view.
# Prefer VITE_GA_MEASUREMENT_ID **or** VITE_GTM_ID, not both (avoids duplicate hits).
VITE_GA_MEASUREMENT_ID=
# Optional: GA4 DebugView (verbose logging)
# VITE_GA_DEBUG=true

# Google Tag Manager container ID (e.g. GTM-XXXXXXX) — use if GA4 is deployed via GTM instead of above.
VITE_GTM_ID=
